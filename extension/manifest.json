{
  "manifest_version": 3,
  "name": "Cloudly",
  "version": "1.0.0",
  "description": "Local encrypted cloud file manager",

  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "http://localhost:4242/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "side_panel": {
    "default_path": "side-panel/index.html"
  },

  "action": {
    "default_title": "Cloudly",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/inspector.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
